---
// Layout partagé : <head> SEO (title/description/canonical/Open Graph par page),
// fonts self-hébergées, tokens de marque globaux, header + footer.
// Ton sobre, anti-décoratif (pas d'emoji, pas de gradient, pas d'ombre décorative).
import "@fontsource-variable/plus-jakarta-sans/wght.css";
import "@fontsource/noto-naskh-arabic/arabic-700.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  /** Canonique explicite (sinon dérivée de l'URL courante). */
  canonical?: string;
  /** Image Open Graph (chemin relatif au site ou URL absolue). */
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = ogImage ? new URL(ogImage, Astro.site).href : undefined;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / réseaux -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Fahemtu" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="fr_FR" />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}
    <meta
      name="twitter:card"
      content={ogImageURL ? "summary_large_image" : "summary"}
    />

    <!-- Révélation au scroll — progressive enhancement.
         On active l'effet (et donc l'état masqué initial) AVANT le 1er paint,
         uniquement si JS + mouvement autorisé + IntersectionObserver dispo.
         Sans JS / crawlers / reduced-motion → la classe n'est jamais posée,
         le contenu reste visible (jamais masqué derrière le JS). -->
    <script is:inline>
      (function () {
        try {
          var ok =
            "IntersectionObserver" in window &&
            !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          if (ok) document.documentElement.classList.add("reveal-enabled");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Header />
    <main class="container">
      <slot />
    </main>
    <Footer />

    <!-- Hauteur réelle du header → --header-h (centrage exact du hero plein
         écran, même si le header wrappe). Mis à jour au resize. Sans JS, le
         repli CSS (--header-h) reste utilisé : centrage approximatif, jamais cassé. -->
    <script is:inline>
      (function () {
        var header = document.querySelector("header");
        if (!header) return;
        var apply = function () {
          document.documentElement.style.setProperty(
            "--header-h",
            header.offsetHeight + "px",
          );
        };
        apply();
        if (window.ResizeObserver) new ResizeObserver(apply).observe(header);
        else window.addEventListener("resize", apply);
      })();
    </script>

    <style is:global>
      :root {
        /* Tokens de marque */
        --creme: #f4efe5;
        --encre: #1a1816;
        --ocre: #b8893e;
        --teal: #2e5a56;

        --font-sans: "Plus Jakarta Sans Variable", system-ui, sans-serif;
        --font-arabic: "Noto Naskh Arabic", serif;

        /* Bornes horizontales partagées header + body + footer (alignement). */
        --shell-max: 64rem;
        --shell-pad: 1.5rem;
        /* Padding vertical du conteneur (réutilisé par le hero plein écran). */
        --container-pad-y: 3rem;
        /* Repli avant JS / sans JS. Remplacé à l'exécution par la hauteur
           RÉELLE du header (mesurée), pour un centrage exact même si le header
           wrappe (mobile). Voir le script en bas de body. */
        --header-h: 3.9rem;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        background: var(--creme);
        color: var(--encre);
        font-family: var(--font-sans);
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        display: flex;
        flex-direction: column;
        min-height: 100svh;
      }

      main {
        flex: 1;
      }

      .container {
        max-width: var(--shell-max);
        margin: 0 auto;
        padding: var(--container-pad-y) var(--shell-pad);
      }

      /* Hero plein écran (pages vitrine) : occupe la BANDE visible sous le header
         (hauteur réelle du header mesurée à l'exécution → --header-h, sans valeur
         dépendante d'un header figé) et centre son contenu dans cette bande →
         espaces vides haut/bas égaux. On neutralise le padding-top du conteneur
         (via :has) pour que la bande démarre pile sous le header, sans marge
         négative. min-height (pas height) → écran court : la section grandit et
         défile, contenu jamais coupé. svh = plus petit viewport, sans jank. */
      .container:has(> .hero-full) {
        padding-top: 0;
      }
      .hero-full {
        min-height: calc(100svh - var(--header-h));
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      h1,
      h2,
      h3 {
        line-height: 1.2;
        letter-spacing: -0.015em;
        font-weight: 700;
      }

      a {
        color: var(--teal);
      }

      p {
        margin: 0 0 1rem;
      }

      /* Révélation au scroll : un seul effet, homogène sur tous les blocs
         principaux (enfants directs de <main>). Uniquement opacity + transform
         → aucun layout shift. Actif seulement quand .reveal-enabled est posé
         (JS + mouvement autorisé) ; sinon le contenu est visible par défaut. */
      @media (prefers-reduced-motion: no-preference) {
        .reveal-enabled main > * {
          opacity: 0;
          transform: translateY(14px);
        }
        .reveal-enabled main > .is-visible {
          opacity: 1;
          transform: none;
          transition:
            opacity 550ms ease-out,
            transform 550ms ease-out;
        }
      }
    </style>

    <!-- Observe chaque bloc principal et le révèle une seule fois. Bundlé et
         différé par Astro ; ne s'exécute que si l'effet a été activé. -->
    <script>
      if (document.documentElement.classList.contains("reveal-enabled")) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.05 },
        );
        for (const el of document.querySelectorAll("main > *")) io.observe(el);
      }
    </script>
  </body>
</html>
