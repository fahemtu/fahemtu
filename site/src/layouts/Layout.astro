---
// Layout partagé : <head> SEO (title/description/canonical/Open Graph par page),
// fonts self-hébergées, tokens de marque globaux, header + footer.
// Ton sobre, anti-décoratif (pas d'emoji, pas de gradient, pas d'ombre décorative).
import "@fontsource-variable/plus-jakarta-sans/wght.css";
import "@fontsource/noto-naskh-arabic/arabic-700.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  /** Canonique explicite (sinon dérivée de l'URL courante). */
  canonical?: string;
  /** Image Open Graph (chemin relatif au site ou URL absolue). */
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = ogImage ? new URL(ogImage, Astro.site).href : undefined;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / réseaux -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Fahemtu" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="fr_FR" />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}
    <meta
      name="twitter:card"
      content={ogImageURL ? "summary_large_image" : "summary"}
    />

    <!-- Révélation au scroll — progressive enhancement.
         On active l'effet (et donc l'état masqué initial) AVANT le 1er paint,
         uniquement si JS + mouvement autorisé + IntersectionObserver dispo.
         Sans JS / crawlers / reduced-motion → la classe n'est jamais posée,
         le contenu reste visible (jamais masqué derrière le JS). -->
    <script is:inline>
      (function () {
        try {
          var ok =
            "IntersectionObserver" in window &&
            !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          if (ok) document.documentElement.classList.add("reveal-enabled");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Header />
    <main class="container">
      <slot />
    </main>
    <Footer />

    <style is:global>
      :root {
        /* Tokens de marque */
        --creme: #f4efe5;
        --encre: #1a1816;
        --ocre: #b8893e;
        --teal: #2e5a56;

        --font-sans: "Plus Jakarta Sans Variable", system-ui, sans-serif;
        --font-arabic: "Noto Naskh Arabic", serif;

        /* Hauteur approximative du header (en flux) — sert au hero plein écran. */
        --header-h: 3.9rem;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        background: var(--creme);
        color: var(--encre);
        font-family: var(--font-sans);
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      main {
        flex: 1;
      }

      .container {
        max-width: 52rem;
        margin: 0 auto;
        padding: 3rem 1.5rem;
      }

      /* Hero plein écran (pages vitrine) : occupe la hauteur visible sous le
         header, contenu centré verticalement. min-height (pas height) → sur
         écran court, la section grandit et défile, le contenu n'est jamais coupé.
         svh = plus petit viewport (barre d'URL mobile visible), sans jank. */
      .hero-full {
        min-height: calc(100svh - var(--header-h));
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      h1,
      h2,
      h3 {
        line-height: 1.2;
        letter-spacing: -0.015em;
        font-weight: 700;
      }

      a {
        color: var(--teal);
      }

      p {
        margin: 0 0 1rem;
      }

      /* Révélation au scroll : un seul effet, homogène sur tous les blocs
         principaux (enfants directs de <main>). Uniquement opacity + transform
         → aucun layout shift. Actif seulement quand .reveal-enabled est posé
         (JS + mouvement autorisé) ; sinon le contenu est visible par défaut. */
      @media (prefers-reduced-motion: no-preference) {
        .reveal-enabled main > * {
          opacity: 0;
          transform: translateY(14px);
        }
        .reveal-enabled main > .is-visible {
          opacity: 1;
          transform: none;
          transition:
            opacity 550ms ease-out,
            transform 550ms ease-out;
        }
      }
    </style>

    <!-- Observe chaque bloc principal et le révèle une seule fois. Bundlé et
         différé par Astro ; ne s'exécute que si l'effet a été activé. -->
    <script>
      if (document.documentElement.classList.contains("reveal-enabled")) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.05 },
        );
        for (const el of document.querySelectorAll("main > *")) io.observe(el);
      }
    </script>
  </body>
</html>
