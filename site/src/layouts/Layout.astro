---
// Layout partagé : <head> SEO (title/description/canonical/Open Graph par page),
// fonts self-hébergées, tokens de marque globaux, header + footer.
// Ton sobre, anti-décoratif (pas d'emoji, pas de gradient, pas d'ombre décorative).
import "@fontsource-variable/plus-jakarta-sans/wght.css";
import "@fontsource/noto-naskh-arabic/arabic-700.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  /** Canonique explicite (sinon dérivée de l'URL courante). */
  canonical?: string;
  /** Image Open Graph (chemin relatif au site ou URL absolue). */
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = ogImage ? new URL(ogImage, Astro.site).href : undefined;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / réseaux -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Fahemtu" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="fr_FR" />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}
    <meta
      name="twitter:card"
      content={ogImageURL ? "summary_large_image" : "summary"}
    />

    <!-- Révélation au scroll — progressive enhancement.
         On active l'effet (et donc l'état masqué initial) AVANT le 1er paint,
         uniquement si JS + mouvement autorisé + IntersectionObserver dispo.
         Sans JS / crawlers / reduced-motion → la classe n'est jamais posée,
         le contenu reste visible (jamais masqué derrière le JS). -->
    <script is:inline>
      (function () {
        try {
          var ok =
            "IntersectionObserver" in window &&
            !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          if (ok) document.documentElement.classList.add("reveal-enabled");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Header />
    <main class="container">
      <slot />
    </main>
    <Footer />

    <!-- Hauteur réelle du header → --header-h (centrage exact du hero plein
         écran, même si le header wrappe). Mis à jour au resize. Sans JS, le
         repli CSS (--header-h) reste utilisé : centrage approximatif, jamais cassé. -->
    <script is:inline>
      (function () {
        var header = document.querySelector("header");
        if (!header) return;
        var apply = function () {
          document.documentElement.style.setProperty(
            "--header-h",
            header.offsetHeight + "px",
          );
        };
        apply();
        if (window.ResizeObserver) new ResizeObserver(apply).observe(header);
        else window.addEventListener("resize", apply);
      })();
    </script>

    <style is:global>
      :root {
        /* Tokens de marque */
        --creme: #f4efe5;
        --encre: #1a1816;
        --ocre: #b8893e;
        --teal: #2e5a56;

        --font-sans: "Plus Jakarta Sans Variable", system-ui, sans-serif;
        --font-arabic: "Noto Naskh Arabic", serif;

        /* Bornes horizontales partagées header + body + footer (alignement). */
        --shell-max: 64rem;
        --shell-pad: 1.5rem;
        /* Padding vertical du conteneur (réutilisé par le hero plein écran). */
        --container-pad-y: 3rem;
        /* Repli avant JS / sans JS. Remplacé à l'exécution par la hauteur
           RÉELLE du header (mesurée), pour un centrage exact même si le header
           wrappe (mobile). Voir le script en bas de body. */
        --header-h: 3.9rem;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        background: var(--creme);
        color: var(--encre);
        font-family: var(--font-sans);
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        display: flex;
        flex-direction: column;
        min-height: 100svh;
      }

      main {
        flex: 1;
      }

      .container {
        /* width: 100% est requis : <main> est un flex item de <body> (flex
           column) ; ses marges inline auto (margin: 0 auto) empêchent le stretch
           → sans width:100%, main prend sa largeur shrink-to-fit (= largeur du
           contenu) puis se centre. Quand le contenu est étroit (texte capé
           42rem), main rétrécit ET se décale vers le centre → tout le hero
           dérive à droite. width:100% force main à occuper la largeur dispo,
           plafonnée à --shell-max et centrée. */
        width: 100%;
        max-width: var(--shell-max);
        margin: 0 auto;
        padding: var(--container-pad-y) var(--shell-pad);
      }

      /* Hero plein écran (pages vitrine) : occupe la BANDE visible sous le header
         (hauteur réelle du header mesurée à l'exécution → --header-h, sans valeur
         dépendante d'un header figé) et centre son contenu dans cette bande →
         espaces vides haut/bas égaux. On neutralise le padding-top du conteneur
         (via :has) pour que la bande démarre pile sous le header, sans marge
         négative. min-height (pas height) → écran court : la section grandit et
         défile, contenu jamais coupé. svh = plus petit viewport, sans jank. */
      .container:has(> .hero-full) {
        padding-top: 0;
      }
      .hero-full {
        min-height: calc(100svh - var(--header-h));
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      /* Hero deux colonnes (pages vitrine) — partagé par /, /mots, /decouvrir :
         texte à gauche (flush-gauche, plafonné) + carte image à droite (desktop).
         La carte (markup + JS) vient du composant HeroCard.astro ; ces styles
         sont communs pour éviter toute divergence/duplication. */
      .hero-grid {
        display: flex;
        align-items: center; /* carte alignée au centre vertical du texte */
        gap: 2.5rem;
      }
      .hero-copy {
        /* Largeur lisible par défaut ; une page peut resserrer (ex. /decouvrir).
           1er item du flex row → bord gauche = conteneur (= marque). */
        max-width: 42rem;
      }
      /* Carte : desktop uniquement. Masquée par défaut (mobile/étroit : pas de
         vide, hero net en une colonne), affichée à partir de 64rem. */
      .hero-card {
        display: none;
        flex: 0 0 auto;
        width: 280px;
        margin-left: auto; /* poussée à droite sans décaler le texte */
        background: #fff;
        border: 1px solid color-mix(in srgb, var(--encre) 12%, transparent);
        border-radius: 14px;
        padding: 0.75rem;
      }
      .hero-card-img {
        display: block;
        width: 100%;
        /* height:auto requis : sans lui, l'attribut HTML height fixe la hauteur
           et neutralise aspect-ratio → image étirée puis rognée. Avec height:auto,
           aspect-ratio 1/1 + width:100% rendent la zone carrée ; source carrée
           dans zone carrée → image entière, rien de rogné. */
        height: auto;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        border-radius: 10px;
      }
      /* Pied de carte : grille 3 colonnes équilibrée → légende (col. centrale)
         centrée par rapport à la carte (spacer gauche = bouton droit) ; bouton en
         col. 3 (coin bas-droit), aucun chevauchement. */
      .hero-card-foot {
        display: grid;
        grid-template-columns: 38px 1fr 38px;
        align-items: center;
        margin-top: 0.6rem;
      }
      .hero-card-play {
        grid-column: 3;
        justify-self: end;
        width: 38px;
        height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        border: none;
        border-radius: 50%;
        background: var(--teal);
        color: var(--creme);
        cursor: pointer;
      }
      .hero-card-play:hover {
        opacity: 0.92;
      }
      .hero-card-play:focus-visible {
        outline: 2px solid var(--teal);
        outline-offset: 2px;
      }
      .hero-card-play svg {
        width: 16px;
        height: 16px;
        display: block;
        fill: currentColor;
      }
      .hero-card-play .icon-pause {
        display: none;
      }
      .hero-card-play.is-playing .icon-play {
        display: none;
      }
      .hero-card-play.is-playing .icon-pause {
        display: block;
      }
      .hero-card-cap {
        grid-column: 2;
        margin: 0;
        text-align: center;
        font-size: 0.85rem;
        color: color-mix(in srgb, var(--encre) 55%, transparent);
      }
      @media (min-width: 64rem) {
        .hero-card {
          display: block;
        }
      }

      h1,
      h2,
      h3 {
        line-height: 1.2;
        letter-spacing: -0.015em;
        font-weight: 700;
      }

      a {
        color: var(--teal);
      }

      p {
        margin: 0 0 1rem;
      }

      /* Révélation au scroll : un seul effet, homogène sur tous les blocs
         principaux (enfants directs de <main>). Uniquement opacity + transform
         → aucun layout shift. Actif seulement quand .reveal-enabled est posé
         (JS + mouvement autorisé) ; sinon le contenu est visible par défaut. */
      @media (prefers-reduced-motion: no-preference) {
        .reveal-enabled main > * {
          opacity: 0;
          transform: translateY(14px);
        }
        .reveal-enabled main > .is-visible {
          opacity: 1;
          transform: none;
          transition:
            opacity 550ms ease-out,
            transform 550ms ease-out;
        }
      }

      /* Entrée soignée au chargement — UNIQUEMENT le hero, une seule fois.
         On neutralise le reveal de BLOC générique pour le hero, et on fait monter
         ses éléments en CASCADE douce (fondu + légère montée, easing lent et
         confiant, sans rebond). Piloté par la même classe .is-visible posée au
         load par l'IntersectionObserver existant. Sans JS / reduced-motion :
         .reveal-enabled n'est jamais posée → tout reste visible immédiatement. */
      @media (prefers-reduced-motion: no-preference) {
        .reveal-enabled main > .hero {
          opacity: 1;
          transform: none;
        }
        .reveal-enabled .hero-copy > *,
        .reveal-enabled .hero-card {
          opacity: 0;
          transform: translateY(12px);
        }
        .reveal-enabled .hero.is-visible .hero-copy > *,
        .reveal-enabled .hero.is-visible .hero-card {
          opacity: 1;
          transform: none;
          transition:
            opacity 520ms cubic-bezier(0.22, 1, 0.36, 1),
            transform 520ms cubic-bezier(0.22, 1, 0.36, 1);
        }
        .reveal-enabled .hero.is-visible .hero-copy > *:nth-child(1) {
          transition-delay: 60ms;
        }
        .reveal-enabled .hero.is-visible .hero-copy > *:nth-child(2) {
          transition-delay: 140ms;
        }
        .reveal-enabled .hero.is-visible .hero-copy > *:nth-child(3) {
          transition-delay: 220ms;
        }
        .reveal-enabled .hero.is-visible .hero-copy > *:nth-child(4) {
          transition-delay: 300ms;
        }
        .reveal-enabled .hero.is-visible .hero-copy > *:nth-child(5) {
          transition-delay: 380ms;
        }
        .reveal-enabled .hero.is-visible .hero-card {
          transition-delay: 300ms;
        }
      }
    </style>

    <!-- Observe chaque bloc principal et le révèle une seule fois. Bundlé et
         différé par Astro ; ne s'exécute que si l'effet a été activé. -->
    <script>
      if (document.documentElement.classList.contains("reveal-enabled")) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.05 },
        );
        for (const el of document.querySelectorAll("main > *")) io.observe(el);
      }
    </script>
  </body>
</html>
