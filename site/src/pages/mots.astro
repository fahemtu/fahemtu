---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Les mots qui débloquent l'arabe — Fahemtu"
  description="67 mots arabes à comprendre à l'oreille, par le son et l'image. La première brique de Fahemtu."
>
  <section class="sales">
    <p class="kicker">Produit 1</p>
    <h1>Les mots qui débloquent l'arabe</h1>
    <p class="lead">
      67 mots essentiels, appris à l'oreille : on écoute l'arabe, on reconnaît
      l'image, on comprend. Aucun texte arabe, aucune traduction à mémoriser.
    </p>

    <div class="placeholder" aria-hidden="true">
      <p>Argumentaire détaillé, démonstration et tarif — à venir.</p>
    </div>

    <!-- Lien vers l'app à définir (placeholder). -->
    <a class="cta" href="#app">Commencer</a>
  </section>
</Layout>

<style>
  .sales {
    max-width: 38rem;
  }
  .kicker {
    font-weight: 600;
    color: var(--ocre);
    margin: 0 0 0.5rem;
  }
  h1 {
    font-size: clamp(1.9rem, 4.5vw, 2.75rem);
    margin: 0 0 1rem;
  }
  .lead {
    font-size: 1.1rem;
    color: color-mix(in srgb, var(--encre) 80%, transparent);
    margin: 0 0 2rem;
  }
  .placeholder {
    border: 1px dashed color-mix(in srgb, var(--encre) 25%, transparent);
    border-radius: 0.6rem;
    padding: 2rem 1.25rem;
    text-align: center;
    color: color-mix(in srgb, var(--encre) 55%, transparent);
    margin-bottom: 2rem;
  }
  .placeholder p {
    margin: 0;
  }
  .cta {
    display: inline-block;
    background: var(--teal);
    color: var(--creme);
    text-decoration: none;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 0.6rem;
  }
  .cta:hover {
    opacity: 0.92;
  }
</style>
