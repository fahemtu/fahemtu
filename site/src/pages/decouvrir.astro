---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Découvre l'arabe à l'oreille — gratuitement | Fahemtu"
  description="Comprends tes premiers mots d'arabe rien qu'en les écoutant, gratuitement et sans inscription. Un avant-goût de la méthode Fahemtu."
>
  <!-- Hero -->
  <section class="block hero-full" aria-labelledby="hero-title">
    <p class="eyebrow">Gratuit — sans inscription</p>
    <h1 id="hero-title">Goûte à l'arabe à l'oreille.</h1>
    <p class="lead">
      En quelques minutes, comprends tes premiers mots d'arabe rien qu'en les
      écoutant. Pas de lecture, pas d'inscription : tu presses play, et tu
      commences.
    </p>
    <a class="cta" href="/app/demo/">Commencer gratuitement</a>
  </section>

  <!-- Comment ça marche -->
  <section class="block" aria-labelledby="comment-title">
    <p class="eyebrow">Comment ça marche</p>
    <p class="explain">
      Tu entends un mot, tu choisis l'image qui lui correspond, et le sens
      s'installe. Une dizaine de mots, quelques minutes — c'est la méthode
      Fahemtu, en version courte.
    </p>
    <a class="cta" href="/app/demo/">Commencer gratuitement</a>
  </section>
</Layout>

<style>
  /* Page courte : un tremplin. */
  .block {
    max-width: 34rem;
    margin: 0 auto 3.5rem;
    text-align: center;
  }
  /* Hero aligné à gauche (modèle /mots) : bloc collé à gauche (margin-inline: 0,
     pas auto), flex column ancré à gauche (align-items: flex-start), texte/bouton
     flush-gauche (text-align: left ; le bouton inline-block épouse son texte).
     justify-content:center (vertical, dans .hero-full global) inchangé.
     Le bloc « Comment ça marche » dessous reste centré (intact). */
  .hero-full {
    /* Section hero PLEINE LARGEUR (comme /mots) → ne peut pas se centrer ; on
       annule le cap 34rem hérité de .block et on force margin-inline: 0. */
    max-width: none;
    margin-inline: 0;
    align-items: flex-start;
    text-align: left;
  }
  /* Texte plafonné (lisibilité) mais ancré à gauche. */
  .hero-full > h1,
  .hero-full > .lead {
    max-width: 42rem;
  }
  .eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ocre);
    margin: 0 0 0.6rem;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 1rem;
  }
  .lead,
  .explain {
    font-size: 1.15rem;
    color: color-mix(in srgb, var(--encre) 82%, transparent);
    margin: 0 0 1.75rem;
  }
  .cta {
    display: inline-block;
    background: var(--teal);
    color: var(--creme);
    text-decoration: none;
    font-weight: 600;
    padding: 0.8rem 1.6rem;
    border-radius: 0.6rem;
  }
  .cta:hover {
    opacity: 0.92;
  }

  /* Accessibilité : focus clavier visible. */
  a:focus-visible {
    outline: 2px solid var(--teal);
    outline-offset: 2px;
  }
</style>
