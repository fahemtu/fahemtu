---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const articles = (await getCollection("articles")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const dateFmt = new Intl.DateTimeFormat("fr-FR", { dateStyle: "long" });
---

<Layout
  title="Articles — Fahemtu"
  description="Réflexions et repères pour apprendre à comprendre l'arabe à l'oreille."
>
  <h1>Articles</h1>
  <ul class="list">
    {
      articles.map((post) => (
        <li>
          <a href={`/articles/${post.id}`}>{post.data.title}</a>
          <time datetime={post.data.date.toISOString()}>
            {dateFmt.format(post.data.date)}
          </time>
          <p>{post.data.description}</p>
        </li>
      ))
    }
  </ul>
</Layout>

<style>
  h1 {
    font-size: clamp(1.9rem, 4.5vw, 2.75rem);
    margin: 0 0 1.5rem;
  }
  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.75rem;
    max-width: 42rem;
  }
  .list a {
    font-size: 1.2rem;
    font-weight: 600;
    text-decoration: none;
  }
  .list a:hover {
    text-decoration: underline;
  }
  time {
    display: block;
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--encre) 55%, transparent);
    margin: 0.2rem 0 0.4rem;
  }
  .list p {
    margin: 0;
    color: color-mix(in srgb, var(--encre) 80%, transparent);
  }
</style>
