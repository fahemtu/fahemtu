---
// Pied de page sobre.
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="inner">
    <p class="tagline">
      <span class="wordmark" lang="ar" dir="rtl" aria-hidden="true">فَهِمْتُ</span>
      Comprendre l'arabe à l'oreille.
    </p>
    <div class="meta">
      <a class="contact" href="mailto:contact@fahemtu.com">contact@fahemtu.com</a>
      <p class="legal">© {year} Fahemtu</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid color-mix(in srgb, var(--encre) 12%, transparent);
    margin-top: 4rem;
  }
  .inner {
    max-width: var(--shell-max);
    margin: 0 auto;
    padding: 2rem var(--shell-pad);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .tagline {
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    color: color-mix(in srgb, var(--encre) 70%, transparent);
    font-size: 0.95rem;
  }
  .wordmark {
    font-family: var(--font-arabic);
    font-weight: 700;
    color: var(--ocre);
  }
  .legal {
    margin: 0;
    color: color-mix(in srgb, var(--encre) 50%, transparent);
    font-size: 0.85rem;
  }
  /* Email de contact + copyright, groupés à droite. */
  .meta {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  /* Email de contact : style sobre du footer, survol discret vers teal. */
  .contact {
    color: color-mix(in srgb, var(--encre) 70%, transparent);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 150ms ease;
  }
  .contact:hover {
    color: var(--teal);
  }
  .contact:focus-visible {
    outline: 2px solid var(--teal);
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>
