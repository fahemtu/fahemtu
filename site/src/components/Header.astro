---
// En-tête de marque sobre : wordmark arabe + « Fahemtu » + navigation.
const links = [
  { href: "/", label: "Accueil" },
  { href: "/mots", label: "Les mots" },
  { href: "/decouvrir", label: "Découvrir" },
  { href: "/guides", label: "Guides" },
];
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header class="site-header">
  <div class="inner">
    <a class="brand" href="/">
      <span class="wordmark" lang="ar" dir="rtl" aria-hidden="true">فَهِمْتُ</span>
      <span class="brand-name">Fahemtu</span>
    </a>
    <nav aria-label="Navigation principale">
      {
        links.map((l) => (
          <a href={l.href} aria-current={isActive(l.href) ? "page" : undefined}>
            {l.label}
          </a>
        ))
      }
      <!-- Connexion : ouvre l'app (/app/) → écran de connexion par lien magique
           (auth Supabase existante). L'accès au produit reste verrouillé par
           l'entitlement ; se connecter sans droit ne donne accès à rien. -->
      <a class="login" href="/app/">Connexion</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid color-mix(in srgb, var(--encre) 12%, transparent);
  }
  .inner {
    max-width: var(--shell-max);
    margin: 0 auto;
    padding: 1rem var(--shell-pad);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--encre);
  }
  .wordmark {
    font-family: var(--font-arabic);
    font-weight: 700;
    font-size: 1.6rem;
    color: var(--ocre);
    line-height: 1;
  }
  .brand-name {
    font-weight: 600;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
  }
  nav {
    display: flex;
    align-items: center; /* aligne verticalement liens de nav + bouton Connexion */
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  nav a {
    text-decoration: none;
    color: color-mix(in srgb, var(--encre) 70%, transparent);
    font-size: 0.95rem;
  }
  nav a:hover {
    color: var(--encre);
  }
  nav a[aria-current="page"] {
    color: var(--teal);
    font-weight: 600;
  }
  /* Connexion : action sobre (pastille teal en contour), distincte des liens de
     nav, dans l'identité. */
  nav a.login {
    color: var(--teal);
    font-weight: 600;
    padding: 0.3rem 0.85rem;
    border: 1px solid color-mix(in srgb, var(--teal) 40%, transparent);
    border-radius: 0.5rem;
  }
  nav a.login:hover {
    color: var(--teal);
    background: color-mix(in srgb, var(--teal) 8%, transparent);
  }
  nav a.login:focus-visible {
    outline: 2px solid var(--teal);
    outline-offset: 2px;
  }
</style>
