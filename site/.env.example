# Fahemtu — site : variables d'environnement SERVEUR.
# NON préfixées PUBLIC_ → jamais exposées au client. Utilisées par l'endpoint
# webhook Stripe (rendu à la demande). Copie ce fichier en .env.local et remplis
# les valeurs (ne JAMAIS committer .env.local).

# Stripe — clé secrète serveur
STRIPE_SECRET_KEY=sk_test_xxx
# Stripe — secret de signature du webhook (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Supabase — URL du projet (ex. https://xxxxxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co
# Supabase — clé SECRÈTE (service role / secret key), JAMAIS la publishable
SUPABASE_SECRET_KEY=your-supabase-secret-key

# Stripe — id du prix du Produit 1 (price_...) → mappé vers « produit-1 »
STRIPE_PRICE_PRODUIT_1=price_xxx

# Resend — email d'accès (envoi best-effort après un achat)
RESEND_API_KEY=re_xxx
# Expéditeur vérifié dans Resend (ex. "Fahemtu <acces@fahemtu.com>")
RESEND_FROM_EMAIL=Fahemtu <acces@your-domain>
# URL de l'app (lien d'accès dans l'email)
APP_URL=https://app.your-domain

# Origine de l'app autorisée pour CORS (endpoint URLs signées)
APP_ORIGIN=http://localhost:5173

# URL de checkout des CTA d'achat de /mots (Stripe Payment Link).
# PUBLIC_ → exposée au client. Test puis live au déploiement.
PUBLIC_CHECKOUT_URL=https://buy.stripe.com/test_xxx

# Beehiiv — capture email du « pic » de la démo (endpoint /api/subscribe).
# Serveur uniquement, jamais exposé au client.
BEEHIIV_API_KEY=beehiiv_xxx
BEEHIIV_PUBLICATION_ID=pub_xxx
