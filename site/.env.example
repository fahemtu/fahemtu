# Fahemtu — site : variables d'environnement SERVEUR.
# NON préfixées PUBLIC_ → jamais exposées au client. Utilisées par l'endpoint
# webhook Stripe (rendu à la demande). Copie ce fichier en .env.local et remplis
# les valeurs (ne JAMAIS committer .env.local).

# Stripe — clé secrète serveur
STRIPE_SECRET_KEY=sk_test_xxx
# Stripe — secret de signature du webhook (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Supabase — URL du projet (ex. https://xxxxxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co
# Supabase — clé SECRÈTE (service role / secret key), JAMAIS la publishable
SUPABASE_SECRET_KEY=your-supabase-secret-key

# Stripe — id du prix du Produit 1 (price_...) → mappé vers « produit-1 »
STRIPE_PRICE_PRODUIT_1=price_xxx
