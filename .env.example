# Fahemtu — variables d'environnement (client Vite, préfixe VITE_).
# Copie ce fichier en .env.local et remplis les valeurs (ne JAMAIS committer .env.local).

# URL du projet Supabase (ex. https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=your-supabase-url

# Clé publiable Supabase (publishable / anon key — destinée au client)
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
